# Function to scale 1–10 → 0–100
def scale(x):
    return x * 10

# New test input (in 1–10 scale)
career_model.input['OPENNESS'] = scale(7.5)
career_model.input['CONSCIENTIOUSNESS'] = scale(8)
career_model.input['EXTRAVERSION'] = scale(6)
career_model.input['AGREEABLENESS'] = scale(7)
career_model.input['NEUROTICISM'] = scale(3)

# Compute result
career_model.compute()

# Output
score = career_model.output['CAREER']
print("Career Score:", score)

plt.figure(figsize=(6,4))
plt.hist(df['Career Score'], bins=10)
plt.title("Career Score Distribution")
plt.xlabel("Score")
plt.ylabel("Frequency")
plt.show()
